.DS_Store
Thumbs.db

# VS Code settings
.vscode/

# JetBrains IDE
.idea/

# GoLand project files
*.iml

# Coverage reports
coverage.out

# Node modules (if you add scripts later)
node_modules/

# Test binary
*.test

# Debug files
__debug_bin

# Go build cache (optional)
go-build/
